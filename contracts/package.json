{
  "name": "energyfi-contracts",
  "version": "1.0.0",
  "type": "module",
  "description": "Smart contracts deployed to the EnergyFi L1 (Avalanche L1 private chain).",
  "scripts": {
    "compile": "npx hardhat compile && npm run typechain",
    "typechain": "typechain --target ethers-v6 --out-dir typechain-types 'artifacts/contracts/**/*.json'",
    "test": "npm run test:unit",
    "test:unit": "npx hardhat test",
    "test:integration": "npx hardhat test test/integration/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "clean": "npx hardhat clean",
    "node": "npx hardhat node",
    "deploy:essential:testnet": "npx hardhat run scripts/deploy/essential.ts --network energyfi-l1-testnet",
    "deploy:surface:testnet": "npx hardhat run scripts/deploy/surface.ts --network energyfi-l1-testnet",
    "seed:demo:testnet": "npx hardhat run scripts/seed/demo.ts --network energyfi-l1-testnet",
    "judge:testnet": "tsx scripts/verify/judge-demo.ts",
    "dashboard:testnet": "tsx tools/dashboard/server.ts energyfi-l1-testnet"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@noble/curves": "^2.0.1",
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.4",
    "@nomicfoundation/hardhat-ignition": "^3.0.7",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.0.7",
    "@nomicfoundation/hardhat-keystore": "^3.0.4",
    "@nomicfoundation/hardhat-mocha": "^3.0.11",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.3",
    "@nomicfoundation/hardhat-verify": "^3.0.10",
    "@nomicfoundation/ignition-core": "^3.0.7",
    "@openzeppelin/contracts": "^5.3.0",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.13",
    "chai": "^6.2.2",
    "dotenv": "^16.4.0",
    "ethers": "^6.14.0",
    "hardhat": "^3.1.7",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1"
  }
}
