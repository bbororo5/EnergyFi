# ==============================================================================
# EnergyFi Environment Variables
# Copy this file to .env and fill in the values.
# ==============================================================================

# [Deployer Key]
DEPLOYER_PRIVATE_KEY=

# [EnergyFi L1 RPC Endpoint]
# AvaCloud EnergyFi L1 testnet (Chain ID 270626)
ENERGYFI_L1_TESTNET_RPC=
# Optional override for AvaCloud demo chains that use a different chain id.
ENERGYFI_L1_TESTNET_CHAIN_ID=270626

# [Deployment Roles]
ENERGYFI_ADMIN_ADDRESS=
ENERGYFI_BRIDGE_ADDRESS=
ENERGYFI_REPUTATION_BRIDGE_ADDRESS=

# [Contract Addresses – populated after deploy]
# Category A: Physical Infrastructure
STATION_REGISTRY_ADDRESS=

# Category B: Charging Data & Carbon Reduction
CHARGE_TRANSACTION_ADDRESS=
CARBON_REDUCTION_ADDRESS=
PARAMETER_REGISTRY_ADDRESS=

# Category C: Carbon Credit Pipeline
CARBON_BATCH_ADDRESS=
VCU_REFERENCE_ADDRESS=

# Category D: Investment & Operations
REPUTATION_REGISTRY_ADDRESS=
STO_PORTFOLIO_ADDRESS=
REGION_STO_FACTORY_ADDRESS=

# [External API]
APEX_API_URL=

# [Frontend – React Native + Expo]
WALLETCONNECT_PROJECT_ID=
