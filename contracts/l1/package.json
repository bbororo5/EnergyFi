    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "clean": "npx hardhat clean",
    "node": "npx hardhat node",
    "deploy:local": "npx hardhat run scripts/deploy_subnet.ts --network energyfi-l1-local",
    "deploy:testnet": "npx hardhat run scripts/deploy_subnet.ts --network energyfi-l1-testnet",
    "deploy:mainnet": "npx hardhat run scripts/deploy_subnet.ts --network energyfi-l1-mainnet",
    "dashboard:testnet": "tsx scripts/dashboard/web/server.ts energyfi-l1-testnet",
    "dashboard:local": "tsx scripts/dashboard/web/server.ts localhost",
    "dashboard:l1-local": "tsx scripts/dashboard/web/server.ts energyfi-l1-local"
  },
  "keywords": [],
