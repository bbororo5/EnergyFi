    "chai": "^6.2.2",
    "dotenv": "^16.4.0",
    "ethers": "^6.14.0",
    "hardhat": "^3.1.7",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
